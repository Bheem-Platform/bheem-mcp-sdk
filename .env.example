# ─────────────────────────────────────────────
# MCP Server Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Port this MCP server listens on (pick an unused port: 9012, 9013, etc.)
MCP_PORT=9012

# REQUIRED: The externally reachable URL of this MCP server.
# The orchestrator (agents.agentbheem.com) calls this URL to reach your tools.
# Use your server's public IP or domain — NOT localhost.
# Example: http://10.0.0.5:9012/mcp or https://orders-mcp.yourdomain.com/mcp
MCP_EXTERNAL_URL=http://<YOUR_SERVER_IP>:9012/mcp

# Optional auth token. If set, all requests must include:
#   Authorization: Bearer <this token>
# Leave empty for no auth (dev only)
MCP_AUTH_TOKEN=

# REQUIRED: Your backend API base URL
# This is the service your tools call under the hood — NOT localhost.
# Example: https://api.yourdomain.com or http://10.0.0.5:8000
BACKEND_API_URL=

# Bheem orchestrator URL for template self-registration
ORCHESTRATOR_URL=https://agents.agentbheem.com

# Optional: RAG service URL (if your module has knowledge base search)
RAG_SERVICE_URL=
